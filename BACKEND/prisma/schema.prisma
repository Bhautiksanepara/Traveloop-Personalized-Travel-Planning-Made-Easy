generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                String               @id @default(dbgenerated("(UUID())")) @db.Char(36)
  name              String               @db.VarChar(120)
  email             String               @unique(map: "uq_users_email") @db.VarChar(255)
  passwordHash      String               @map("password_hash") @db.VarChar(255)
  avatarUrl         String?              @map("avatar_url") @db.Text
  language          String               @default("en") @db.VarChar(10)
  isAdmin           Boolean              @default(false) @map("is_admin")
  isDeleted         Boolean              @default(false) @map("is_deleted")
  createdAt         DateTime             @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt         DateTime             @default(now()) @updatedAt @map("updated_at") @db.DateTime(0)
  trips             Trip[]
  savedDestinations SavedDestination[]
  refreshTokens     RefreshToken[]
  passwordResets    PasswordResetToken[]

  @@index([isDeleted], map: "idx_users_is_deleted")
  @@map("users")
}

model City {
  id              String             @id @default(dbgenerated("(UUID())")) @db.Char(36)
  name            String             @db.VarChar(120)
  country         String             @db.VarChar(100)
  region          String?            @db.VarChar(100)
  costIndex       Decimal            @default(50.00) @map("cost_index") @db.Decimal(5, 2)
  popularityScore Int                @default(0) @map("popularity_score")
  imageUrl        String?            @map("image_url") @db.Text
  latitude        Decimal?           @db.Decimal(9, 6)
  longitude       Decimal?           @db.Decimal(9, 6)
  createdAt       DateTime           @default(now()) @map("created_at") @db.DateTime(0)
  activities      Activity[]
  tripStops       TripStop[]
  savedByUsers    SavedDestination[]

  @@index([country, name], map: "idx_cities_country")
  @@index([popularityScore(sort: Desc)], map: "idx_cities_popularity")
  @@index([latitude, longitude], map: "idx_cities_geo")
  @@map("cities")
}

model Activity {
  id              String         @id @default(dbgenerated("(UUID())")) @db.Char(36)
  cityId          String         @map("city_id") @db.Char(36)
  name            String         @db.VarChar(200)
  description     String?        @db.Text
  category        String         @default("other") @db.VarChar(60)
  estimatedCost   Decimal        @default(0.00) @map("estimated_cost") @db.Decimal(10, 2)
  durationMinutes Int?           @map("duration_minutes")
  imageUrl        String?        @map("image_url") @db.Text
  createdAt       DateTime       @default(now()) @map("created_at") @db.DateTime(0)
  city            City           @relation(fields: [cityId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  stopActivities  StopActivity[]

  @@index([cityId, category], map: "idx_activities_city_cat")
  @@index([cityId, estimatedCost], map: "idx_activities_cost")
  @@map("activities")
}

model Trip {
  id             String         @id @default(dbgenerated("(UUID())")) @db.Char(36)
  userId         String         @map("user_id") @db.Char(36)
  name           String         @db.VarChar(200)
  description    String?        @db.Text
  startDate      DateTime       @map("start_date") @db.Date
  endDate        DateTime       @map("end_date") @db.Date
  coverPhotoUrl  String?        @map("cover_photo_url") @db.Text
  budgetLimit    Decimal?       @map("budget_limit") @db.Decimal(10, 2)
  isPublic       Boolean        @default(false) @map("is_public")
  slug           String?        @unique(map: "uq_trips_slug") @db.VarChar(80)
  createdAt      DateTime       @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt      DateTime       @default(now()) @updatedAt @map("updated_at") @db.DateTime(0)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  stops          TripStop[]
  expenses       TripExpense[]
  packingItems   PackingItem[]
  notes          TripNote[]
  sharedTrip     SharedTrip?

  @@index([userId, startDate(sort: Desc)], map: "idx_trips_user_date")
  @@index([isPublic, createdAt(sort: Desc)], map: "idx_trips_public")
  @@map("trips")
}

model TripStop {
  id             String         @id @default(dbgenerated("(UUID())")) @db.Char(36)
  tripId         String         @map("trip_id") @db.Char(36)
  cityId         String         @map("city_id") @db.Char(36)
  arriveDate     DateTime       @map("arrive_date") @db.Date
  departDate     DateTime       @map("depart_date") @db.Date
  orderIndex     Int            @default(0) @map("order_index")
  budgetForStop  Decimal?       @map("budget_for_stop") @db.Decimal(10, 2)
  createdAt      DateTime       @default(now()) @map("created_at") @db.DateTime(0)
  trip           Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  city           City           @relation(fields: [cityId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  activities     StopActivity[]
  expenses       TripExpense[]
  notes          TripNote[]

  @@unique([tripId, orderIndex], map: "uq_stop_order")
  @@index([tripId, orderIndex(sort: Asc)], map: "idx_stops_trip_order")
  @@index([cityId], map: "idx_stops_city")
  @@map("trip_stops")
}

model StopActivity {
  id            String    @id @default(dbgenerated("(UUID())")) @db.Char(36)
  stopId        String    @map("stop_id") @db.Char(36)
  activityId    String    @map("activity_id") @db.Char(36)
  scheduledTime DateTime? @map("scheduled_time") @db.Time(0)
  actualCost    Decimal?  @map("actual_cost") @db.Decimal(10, 2)
  orderIndex    Int       @default(0) @map("order_index")
  createdAt     DateTime  @default(now()) @map("created_at") @db.DateTime(0)
  stop          TripStop  @relation(fields: [stopId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  activity      Activity  @relation(fields: [activityId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([stopId, activityId], map: "uq_stop_activity")
  @@index([stopId, orderIndex(sort: Asc)], map: "idx_stop_act_stop")
  @@index([activityId], map: "idx_stop_act_activity")
  @@map("stop_activities")
}

model TripExpense {
  id          String    @id @default(dbgenerated("(UUID())")) @db.Char(36)
  tripId      String    @map("trip_id") @db.Char(36)
  stopId      String?   @map("stop_id") @db.Char(36)
  category    String    @default("other") @db.VarChar(60)
  label       String?   @db.VarChar(200)
  amount      Decimal   @db.Decimal(10, 2)
  expenseDate DateTime  @map("expense_date") @db.Date
  notes       String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at") @db.DateTime(0)
  trip        Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  stop        TripStop? @relation(fields: [stopId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([tripId, category], map: "idx_expenses_trip_cat")
  @@index([tripId, expenseDate], map: "idx_expenses_trip_date")
  @@index([stopId], map: "idx_expenses_stop")
  @@map("trip_expenses")
}

model PackingItem {
  id         String   @id @default(dbgenerated("(UUID())")) @db.Char(36)
  tripId     String   @map("trip_id") @db.Char(36)
  name       String   @db.VarChar(200)
  category   String   @default("other") @db.VarChar(60)
  isPacked   Boolean  @default(false) @map("is_packed")
  orderIndex Int      @default(0) @map("order_index")
  createdAt  DateTime @default(now()) @map("created_at") @db.DateTime(0)
  trip       Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([tripId, category, orderIndex], map: "idx_packing_trip_cat")
  @@map("packing_items")
}

model TripNote {
  id        String    @id @default(dbgenerated("(UUID())")) @db.Char(36)
  tripId    String    @map("trip_id") @db.Char(36)
  stopId    String?   @map("stop_id") @db.Char(36)
  content   String    @db.Text
  noteDate  DateTime  @default(now()) @map("note_date") @db.Date
  createdAt DateTime  @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at") @db.DateTime(0)
  trip      Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  stop      TripStop? @relation(fields: [stopId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([tripId, noteDate(sort: Desc)], map: "idx_notes_trip_date")
  @@index([stopId], map: "idx_notes_stop")
  @@map("trip_notes")
}

model SharedTrip {
  id          String   @id @default(dbgenerated("(UUID())")) @db.Char(36)
  tripId      String   @unique(map: "uq_shared_trip_id") @map("trip_id") @db.Char(36)
  publicToken String   @unique(map: "uq_shared_token") @map("public_token") @db.VarChar(40)
  isActive    Boolean  @default(true) @map("is_active")
  viewCount   Int      @default(0) @map("view_count")
  createdAt   DateTime @default(now()) @map("created_at") @db.DateTime(0)
  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([publicToken, isActive], map: "idx_shared_token_active")
  @@map("shared_trips")
}

model SavedDestination {
  id       String   @id @default(dbgenerated("(UUID())")) @db.Char(36)
  userId   String   @map("user_id") @db.Char(36)
  cityId   String   @map("city_id") @db.Char(36)
  savedAt  DateTime @default(now()) @map("saved_at") @db.DateTime(0)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  city     City     @relation(fields: [cityId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([userId, cityId], map: "uq_saved_dest")
  @@index([userId, savedAt(sort: Desc)], map: "idx_saved_user")
  @@map("saved_destinations")
}

model RefreshToken {
  id          String   @id @default(uuid()) @db.Char(36)
  userId      String   @map("user_id") @db.Char(36)
  tokenHash   String   @map("token_hash") @db.VarChar(255)
  deviceLabel String?  @map("device_label") @db.VarChar(120)
  expiresAt   DateTime @map("expires_at") @db.DateTime(0)
  revokedAt   DateTime? @map("revoked_at") @db.DateTime(0)
  createdAt   DateTime @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.DateTime(0)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId], map: "idx_refresh_tokens_user")
  @@index([expiresAt], map: "idx_refresh_tokens_expires")
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id         String    @id @default(uuid()) @db.Char(36)
  userId     String    @map("user_id") @db.Char(36)
  tokenHash  String    @map("token_hash") @db.VarChar(255)
  expiresAt  DateTime  @map("expires_at") @db.DateTime(0)
  consumedAt DateTime? @map("consumed_at") @db.DateTime(0)
  createdAt  DateTime  @default(now()) @map("created_at") @db.DateTime(0)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId], map: "idx_password_reset_tokens_user")
  @@index([expiresAt], map: "idx_password_reset_tokens_expires")
  @@map("password_reset_tokens")
}
