{
  "name": "traveloop-backend",
  "version": "1.0.0",
  "description": "Traveloop backend API built with Express, Prisma, and MySQL.",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "prisma:generate": "prisma generate",
    "test": "vitest run",
    "test:db": "node tests/db-connection-check.js",
    "test:api": "vitest run tests/api.integration.test.mjs",
    "test:seed": "vitest run tests/seed.integration.test.mjs"
  },
  "keywords": [
    "traveloop",
    "express",
    "prisma",
    "mysql"
  ],
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "^6.8.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "nodemailer": "^6.10.0",
    "uuid": "^11.0.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "nodemon": "^3.1.7",
    "prisma": "^6.8.2",
    "supertest": "^7.1.1",
    "vitest": "^2.1.3"
  }
}
